# Verification tooling: fetched reference cache + Python bytecode + generated reports
tool/.cache/
tool/__pycache__/
tool/uthmani_diff_*.html
tool/uthmani_verification*

# Flutter / Dart
.dart_tool/
.packages
build/
.flutter-plugins
.flutter-plugins-dependencies
pubspec.lock

# Generated code (run: dart run build_runner build)
*.g.dart

# Patrol-generated E2E bundle (regenerated by `patrol test`)
integration_test/test_bundle.dart
/patrol_test/
*.freezed.dart

# IDE
.idea/
.vscode/
*.iml

# OS
.DS_Store

# Platform runners. android/ & ios/ are now COMMITTED — the app ships native
# home-screen widget code (iOS WidgetKit extension + Android receiver) that must
# live in version control. Build artifacts inside them are excluded by
# android/.gitignore and ios/.gitignore. The unused desktop/web runners are still
# generated locally with `flutter create`, so stay ignored.
/linux/
/macos/
/windows/
/web/


tool/indopak_diff_*.html
tool/uthmani_deltas.html

# Release signing — owner-supplied, never commit
android/key.properties
*.jks
*.keystore

# Scratch / working art (brand previews, masks, rasterized PDFs)
tmp/

# Recitation audio staging — fetched MP3s live here on their way to R2, never
# committed (R2 is the store; see tool/audio/README.md).
tool/audio/staging/
tool/audio/__pycache__/
