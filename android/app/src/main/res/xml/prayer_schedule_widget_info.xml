<?xml version="1.0" encoding="utf-8"?>
<!-- Wide "today's prayers" widget: 4x1 default, resizable. Same push-driven
     refresh model as the next-prayer widget (updatePeriodMillis=0). -->
<appwidget-provider xmlns:android="http://schemas.android.com/apk/res/android"
    android:minWidth="250dp"
    android:minHeight="70dp"
    android:minResizeWidth="180dp"
    android:minResizeHeight="60dp"
    android:targetCellWidth="4"
    android:targetCellHeight="1"
    android:description="@string/prayer_schedule_widget_description"
    android:initialLayout="@layout/prayer_schedule_widget"
    android:previewLayout="@layout/prayer_schedule_widget"
    android:resizeMode="horizontal|vertical"
    android:updatePeriodMillis="0"
    android:widgetCategory="home_screen" />
