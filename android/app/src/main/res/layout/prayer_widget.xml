<?xml version="1.0" encoding="utf-8"?>
<!-- "Next prayer" home-screen widget (small). Text is set at runtime by
     PrayerWidgetProvider; the only static string is the "Next prayer" label. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@drawable/prayer_widget_bg"
    android:padding="14dp">

    <TextView
        android:id="@+id/widget_location"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxLines="1"
        android:ellipsize="end"
        android:textColor="#B8C9C3"
        android:textSize="11sp" />

    <TextView
        android:id="@+id/widget_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:letterSpacing="0.12"
        android:textAllCaps="true"
        android:textColor="#8FB3AA"
        android:textSize="10sp"
        android:text="@string/widget_label" />

    <TextView
        android:id="@+id/widget_prayer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="#F4F1E9"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textColor="#E4D9B8"
        android:textSize="16sp" />
</LinearLayout>
